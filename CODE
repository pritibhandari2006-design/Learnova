
function welcomeMsg() {
    alert("Welcome to Learnova! Start Learning Smart 📚");
}

// Quiz logic
let currentQuiz = 0;
const quizQuestions = [
    {question: "What is i² (iota square)?", options: ["1","-1","0"], answer: "-1"},
    {question: "What is the derivative of x²?", options: ["x","2x","x²"], answer: "2x"},
    {question: "What is H₂O commonly known as?", options: ["Water","Oxygen","Hydrogen"], answer: "Water"}
];

function loadQuiz() {
    let q = quizQuestions[currentQuiz];
    document.getElementById("quiz-question").innerText = q.question;
    let optionsDiv = document.getElementById("quiz-options");
    optionsDiv.innerHTML = "";
    q.options.forEach(opt => {
        let btn = document.createElement("button");
        btn.innerText = opt;
        btn.onclick = () => checkAnswer(opt);
        optionsDiv.appendChild(btn);
    });
    document.getElementById("result").innerText = "";
}

function checkAnswer(ans) {
    let correctAns = quizQuestions[currentQuiz].answer;
    let result = document.getElementById("result");
    if(ans === correctAns) {
        result.innerHTML = "Correct! ✅";
        result.style.color = "#27ae60";
    } else {
        result.innerHTML = "Wrong Answer ❌ Try Again!";
        result.style.color = "#e74c3c";
    }
}

// Feedback logic
function submitFeedback() {
    let box = document.getElementById("feedback-box");
    let display = document.getElementById("feedback-display");
    if(box.value.trim() !== "") {
        let p = document.createElement("p");
        p.innerText = box.value;
        display.appendChild(p);
        box.value = "";
        alert("Thank you for your feedback!");
    } else {
        alert("Please write something before submitting.");
    }
}

// Initialize first quiz
loadQuiz();
</script>

